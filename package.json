{
  "name": "five-agent-dev-team",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first autonomous five-agent software development team controller.",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -n controller,worker,dashboard -c blue,green,magenta \"npm:dev:controller\" \"npm:dev:worker\" \"npm:dev:dashboard\"",
    "dev:controller": "tsx watch apps/controller/src/index.ts",
    "dev:worker": "tsx watch apps/worker/src/index.ts",
    "dev:dashboard": "vite --config apps/dashboard/vite.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && vite build --config apps/dashboard/vite.config.ts",
    "audit:security": "node scripts/check-npm-audit.mjs",
    "start:controller": "node dist/apps/controller/src/index.js",
    "start:worker": "node dist/apps/worker/src/index.js",
    "start:dashboard": "vite preview --config apps/dashboard/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "test": "vitest run --exclude tests/e2e/**",
    "test:acceptance": "vitest run tests/acceptance",
    "test:e2e": "playwright test",
    "verify:local": "node scripts/verify-local.mjs",
    "verify:ci": "node scripts/verify-ci.mjs",
    "verify:captain": "node scripts/verify-captain.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test && npm run build",
    "verify:targeted": "node scripts/verify-targeted.mjs",
    "verify:pr": "node scripts/verify-pr-ready.mjs",
    "verify:runtime": "node scripts/verify-runtime.mjs",
    "ci:route": "node scripts/ci-failure-router.mjs",
    "ops:janitor": "node scripts/janitor.mjs",
    "logs:check": "node scripts/validate-logging.mjs",
    "spec:hash": "node scripts/spec-hash.mjs",
    "diff:budget": "node scripts/diff-budget-check.mjs"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@openai/agents": "^0.8.5",
    "@temporalio/client": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.6.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}

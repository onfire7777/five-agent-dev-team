{
  "name": "five-agent-dev-team",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first autonomous five-agent software development team controller.",
  "scripts": {
    "dev": "concurrently -n controller,worker,dashboard -c blue,green,magenta \"npm:dev:controller\" \"npm:dev:worker\" \"npm:dev:dashboard\"",
    "dev:controller": "tsx watch apps/controller/src/index.ts",
    "dev:worker": "tsx watch apps/worker/src/index.ts",
    "dev:dashboard": "vite --host 0.0.0.0 --config apps/dashboard/vite.config.ts",
    "build": "tsc -p tsconfig.json && vite build --config apps/dashboard/vite.config.ts",
    "start:controller": "node dist/apps/controller/src/index.js",
    "start:worker": "node dist/apps/worker/src/index.js",
    "start:dashboard": "vite preview --host 0.0.0.0 --config apps/dashboard/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@openai/agents": "^0.8.5",
    "@temporalio/client": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.6.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}

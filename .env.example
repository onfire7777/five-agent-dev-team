NODE_ENV=development
PORT=4310
DASHBOARD_PORT=5173
# Leave blank to derive from CONTROLLER_PORT/DASHBOARD_PORT in Docker Compose.
VITE_API_BASE_URL=
CORS_ORIGINS=

# Required for live OpenAI agent runs. Without it, deterministic local agent templates are used.
OPENAI_API_KEY=
AGENT_LIVE_MODE=false
AGENT_EXECUTION_MODE=chatgpt_pro_assisted
# Optional global override. Prefer the per-role model policy below for normal use.
AGENT_MODEL=
AGENT_PRIMARY_MODEL=gpt-5.5
AGENT_RESEARCH_MODEL=gpt-5.5
AGENT_REVIEW_MODEL=gpt-5.5
AGENT_FALLBACK_MODEL=gpt-5.4
# Keep false for autonomous work. Set true only for local smoke tests without a connected target repo.
AGENT_TEAM_ALLOW_DEFAULT_CONFIG=false
AGENT_TEAM_PROJECT_CONFIG_DIR=.agent-team/projects

# Smart continuous workflow defaults. This keeps the system event-driven instead of running five nonstop model loops.
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=60
MAX_CONCURRENT_WORKFLOWS=3
MAX_CONCURRENT_AGENT_RUNS=5
MAX_CONCURRENT_REPO_WRITES=1
ALLOW_PARALLEL_DISJOINT_PROJECTS=true

# Host ports used by Docker Compose.
POSTGRES_PORT=5432
TEMPORAL_PORT=7233

# Host npm dev defaults. Docker Compose overrides these with service DNS names
# inside containers, so this file can be copied for either host or Compose use.
DATABASE_URL=postgres://agent_team:agent_team@127.0.0.1:5432/agent_team
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=agent-team
WORKER_READY_FILE=.agent-team/worker-ready
WORKER_READY_MAX_AGE_MS=30000

# GitHub integration. Prefer a fine-scoped GitHub App token or fine-scoped PAT.
# GitHub CLI accepts GH_TOKEN first; GITHUB_TOKEN is also supported by gh and Octokit.
GH_TOKEN=
GITHUB_TOKEN=
# Official GitHub MCP reads GITHUB_PERSONAL_ACCESS_TOKEN.
# If blank, the runtime mirrors GH_TOKEN/GITHUB_TOKEN into it for MCP startup.
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_HOST=
# Optional dashboard account connection. Prefer fine-grained PAT or GitHub App
# permissions for Contents, Pull requests, Actions, and Metadata. OAuth scopes
# stay blank by default to avoid broad org/repo grants.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_SCOPES=
GITHUB_OWNER=
GITHUB_REPO=
AGENT_TEAM_GITHUB_AUTH_FILE=.agent-team/github-auth.json
TAVILY_API_KEY=
# Optional host path to mount if you choose GitHub CLI config instead of token env.
# Example Windows path: C:\Users\you\AppData\Roaming\GitHub CLI
GH_CONFIG_DIR=

# Explicit project mount/path hints for containerized runs. Keep these project-scoped.
# Set TARGET_REPO_HOST_PATH before Docker Compose if the target repo is outside this controller checkout.
TARGET_REPO_HOST_PATH=
TARGET_REPO_CONTAINER_PATH=/workspace/target-repo
